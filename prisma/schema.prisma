generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hospital {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  overview        String
  specialties     String
  facilities      String
  departments     String
  accreditations  String?
  emergencyInfo   String
  contactInfo     String
  mapUrl          String?
  faqs            String
  author          String
  publishDate     DateTime   @default(now())
  lastUpdated     DateTime   @default(now())
  imageUrl        String?
  imageCredit     String?
  cityId          String?
  specialtyId     String?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  city            City?      @relation(fields: [cityId], references: [id])
  specialty       Specialty? @relation(fields: [specialtyId], references: [id])
}

model BlogPost {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  content         String
  faqs            String?
  references      String?
  author          String
  publishDate     DateTime      @default(now())
  lastUpdated     DateTime      @default(now())
  imageUrl        String?
  imageCredit     String?
  categoryId      String?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  category        BlogCategory? @relation(fields: [categoryId], references: [id])
}

model City {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  hospitals Hospital[]
}

model Specialty {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  hospitals Hospital[]
}

model BlogCategory {
  id    String     @id @default(cuid())
  name  String     @unique
  slug  String     @unique
  posts BlogPost[]
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}
